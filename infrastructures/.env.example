# ===========================================
# INFRASTRUCTURE ENVIRONMENT CONFIGURATION
# ===========================================
# Main configuration file for all infrastructure services

# ===========================================
# SUI NODE CONFIGURATION
# ===========================================
SUI_REMOTE_STORE_URL=https://checkpoints.testnet.sui.io
SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443

# ===========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ===========================================
POSTGRES_DB=sui_indexer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Admin2025@
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:Admin2025@@postgres:5432/sui_indexer

# PostgreSQL Performance
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=4MB

# ===========================================
# ELASTICSEARCH CONFIGURATION
# ===========================================
ES_VERSION=8.15.0
ES_PORT=9200
ES_HEAP_SIZE=1g
ES_CLUSTER_NAME=blockchain-monitor

# Elasticsearch Performance
ES_REFRESH_INTERVAL=30s
ES_NUMBER_OF_SHARDS=3
ES_NUMBER_OF_REPLICAS=1

# Elasticsearch Security
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=Admin2025@
XPACK_SECURITY_ENABLED=false
XPACK_SSL_ENABLED=false

# Elasticsearch Resources
ES_MASTER_JAVA_OPTS=-Xms1g -Xmx1g
ES_DATA_JAVA_OPTS=-Xms2g -Xmx2g
ES_MASTER_CPU_LIMIT=1
ES_MASTER_MEMORY_LIMIT=2G
ES_MASTER_CPU_RESERVATION=0.5
ES_MASTER_MEMORY_RESERVATION=1G
ES_DATA_CPU_LIMIT=2
ES_DATA_MEMORY_LIMIT=4G
ES_DATA_CPU_RESERVATION=1
ES_DATA_MEMORY_RESERVATION=2G

# ===========================================
# KIBANA CONFIGURATION
# ===========================================
KIBANA_PORT=5601
KIBANA_USER=kibana
KIBANA_USERNAME=kibana_system
KIBANA_PASSWORD=Admin2025@
KIBANA_SSL_ENABLED=false
ELASTICSEARCH_URL=http://elasticsearch:9200

# Kibana Resources
KIBANA_CPU_LIMIT=1
KIBANA_MEMORY_LIMIT=2G
KIBANA_CPU_RESERVATION=0.5
KIBANA_MEMORY_RESERVATION=1G

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_PORT=6379
REDIS_PASSWORD=Admin2025@
REDIS_MEMORY_LIMIT=1G
REDIS_MEMORY_RESERVATION=512M

# Redis Persistence
REDIS_SAVE_INTERVAL=900 1
REDIS_APPENDONLY=yes

# ===========================================
# MONITORING CONFIGURATION
# ===========================================
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=Admin2025@

PROMETHEUS_PORT=9090

# ===========================================
# NETWORK CONFIGURATION
# ===========================================
NGINX_PORT=80
NGINX_HTTP_PORT=80
NGINX_SSL_PORT=443
NGINX_HTTPS_PORT=443

# Nginx Resources
NGINX_CPU_LIMIT=1
NGINX_MEMORY_LIMIT=512M
NGINX_CPU_RESERVATION=0.5
NGINX_MEMORY_RESERVATION=256M

# ===========================================
# SECURITY
# ===========================================
JWT_SECRET=Admin2025@
API_KEY=your_api_key_here

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json
